# Fonte única de verdade para todas as variáveis de ambiente.
# Copia para .env.local e preenche os valores reais.
#
# Produção: adiciona cada variável ao GitHub Secrets (Settings → Secrets → Actions).
# O CI/CD sincroniza automaticamente para o Cloudflare em cada deploy.
# Nunca precisas de tocar no dashboard do Cloudflare.

# ─── IA / Chat (Groq) ────────────────────────────────────────────────────────
GROQ_API_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@mail.re-evolution.pt
REEVO_EMAIL=geral@re-evolution.pt

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Integrações externas ─────────────────────────────────────────────────────
MAKE_DIAGNOSTICO_WEBHOOK=

# ─── Funcionalidades ──────────────────────────────────────────────────────────
# Alerta Telegram quando alguém passa 30s+ na secção de preços
INTENT_ALERTS_ENABLED=false

# ─── URL base do site ─────────────────────────────────────────────────────────
# Em desenvolvimento: http://localhost:3000
# Em produção: deixar vazio (usa https://re-evolution.pt por defeito)
NEXT_PUBLIC_SITE_URL=

# ─── Unsubscribe (blog) ───────────────────────────────────────────────────────
# Segredo para assinar os links de cancelamento de subscrição (HMAC-SHA256).
# Gera um valor aleatório forte, ex: openssl rand -hex 32
UNSUBSCRIBE_SECRET=

# ─── Google Sheets (blog leads) ──────────────────────────────────────────────
# Spreadsheet partilhado com a Service Account (ver abaixo).
# Abas: "Subscritores", "PDF Requests", "Cancelados", "Agendamentos"
GOOGLE_SHEETS_ID=
# Email da service account (ex: nome@projecto.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Chave privada da service account (copia o valor completo incluindo -----BEGIN/END-----)
# No GitHub Secrets os \n são escapados automaticamente — o código trata disso.
GOOGLE_PRIVATE_KEY=

# ─── Google Calendar (agendamentos via site) ───────────────────────────────────
# Pré-requisitos:
#   1. Activar "Google Calendar API" no mesmo projecto Google Cloud das Sheets
#   2. Partilhar o calendário com GOOGLE_SERVICE_ACCOUNT_EMAIL (permissão: "Fazer alterações a eventos")
#   3. Copiar o ID do calendário (Definições do calendário → "ID do calendário")
# Formato: xxx@group.calendar.google.com  (ou o teu email para o calendário principal)
GOOGLE_CALENDAR_ID=

# ─── R2 — PDFs dos artigos do blog ───────────────────────────────────────────
# URL pública do bucket R2 (configurada em wrangler.toml [vars] para produção).
# Não é necessária em desenvolvimento local — sem contexto Cloudflare o sistema
# cai automaticamente no email "em breve".
R2_PDF_PUBLIC_URL=https://pdfs.re-evolution.pt

# ─── Analytics ────────────────────────────────────────────────────────────────
GA_MEASUREMENT_ID=
